<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FuelBook" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorPrimaryContainer">@color/bg_surface</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="colorSecondaryContainer">@color/bg_surface</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        
        <!-- Background colors -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_surface</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <!-- NoActionBar theme for MainActivity -->
    <style name="Theme.FuelBook.NoActionBar" parent="Theme.FuelBook">
        <!-- Inherits all from parent -->
    </style>

</resources>