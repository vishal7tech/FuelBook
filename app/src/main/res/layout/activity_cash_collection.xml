<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="#0A0E1A"
    tools:context=".CashCollectionActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/header_dark_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:tint="#4ADE80"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CASH COLLECTION"
                android:textColor="#4ADE80"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.25" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Denomination Count"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="03-01-2026"
            android:textColor="#8A9BB5"
            android:textSize="12sp"
            android:background="@drawable/chip_date_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp" />

    </LinearLayout>


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"

        android:layout_marginBottom="8dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btnSave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Cash Collection Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCashCollection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"

                app:cardBackgroundColor="#111827"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#4ADE80"
                app:strokeWidth="1dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"

                    android:padding="20dp">

                    <!-- Card Title -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@drawable/accent_bar_green"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cash Denominations"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp"
                        android:background="#1E2D45" />

                    <!-- Table Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/table_header_bg"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="DENOMINATION"
                            android:textColor="#4ADE80"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="COUNT"
                            android:textColor="#4ADE80"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="AMOUNT"
                            android:textColor="#4ADE80"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                    </LinearLayout>


                    <TableLayout
                        android:id="@+id/tableCash"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"

                        android:stretchColumns="*">

                        <!-- ₹500 Row -->
                        <TableRow android:layout_marginTop="6dp">

                            <LinearLayout

                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:orientation="horizontal"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹500"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>


                            <EditText
                                android:id="@+id/et500Count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"

                                android:background="@drawable/edittext_dark_bg"

                                android:gravity="center"
                                android:hint="0"
                                android:inputType="number"
                                android:padding="8dp"

                                android:textColor="#E2E8F0"
                                android:textColorHint="#3A4A60"
                                android:textSize="13sp" />


                            <TextView
                                android:id="@+id/tv500Amount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:text="₹0"
                                android:textColor="#4ADE80"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:padding="8dp" />


                        </TableRow>

                        <!-- ₹200 Row -->
                        <TableRow android:layout_marginTop="4dp">


                            <LinearLayout

                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:orientation="horizontal"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹200"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>


                            <EditText
                                android:id="@+id/et200Count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"

                                android:background="@drawable/edittext_dark_bg"

                                android:gravity="center"
                                android:hint="0"
                                android:inputType="number"
                                android:padding="8dp"

                                android:textColor="#E2E8F0"
                                android:textColorHint="#3A4A60"
                                android:textSize="13sp" />


                            <TextView
                                android:id="@+id/tv200Amount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:text="₹0"
                                android:textColor="#4ADE80"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:padding="8dp" />


                        </TableRow>

                        <!-- ₹100 Row -->
                        <TableRow android:layout_marginTop="4dp">


                            <LinearLayout

                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:orientation="horizontal"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹100"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>


                            <EditText
                                android:id="@+id/et100Count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"

                                android:background="@drawable/edittext_dark_bg"

                                android:gravity="center"
                                android:hint="0"
                                android:inputType="number"
                                android:padding="8dp"

                                android:textColor="#E2E8F0"
                                android:textColorHint="#3A4A60"
                                android:textSize="13sp" />


                            <TextView
                                android:id="@+id/tv100Amount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:text="₹0"
                                android:textColor="#4ADE80"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:padding="8dp" />


                        </TableRow>

                        <!-- ₹50 Row -->
                        <TableRow android:layout_marginTop="4dp">


                            <LinearLayout

                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:orientation="horizontal"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹50"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>


                            <EditText
                                android:id="@+id/et50Count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"

                                android:background="@drawable/edittext_dark_bg"

                                android:gravity="center"
                                android:hint="0"
                                android:inputType="number"
                                android:padding="8dp"

                                android:textColor="#E2E8F0"
                                android:textColorHint="#3A4A60"
                                android:textSize="13sp" />


                            <TextView
                                android:id="@+id/tv50Amount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:text="₹0"
                                android:textColor="#4ADE80"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:padding="8dp" />


                        </TableRow>

                        <!-- ₹20 Row -->
                        <TableRow android:layout_marginTop="4dp">


                            <LinearLayout

                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:orientation="horizontal"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹20"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>


                            <EditText
                                android:id="@+id/et20Count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"

                                android:background="@drawable/edittext_dark_bg"

                                android:gravity="center"
                                android:hint="0"
                                android:inputType="number"
                                android:padding="8dp"

                                android:textColor="#E2E8F0"
                                android:textColorHint="#3A4A60"
                                android:textSize="13sp" />


                            <TextView
                                android:id="@+id/tv20Amount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:text="₹0"
                                android:textColor="#4ADE80"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:padding="8dp" />


                        </TableRow>

                        <!-- ₹10 Row -->
                        <TableRow android:layout_marginTop="4dp">


                            <LinearLayout

                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:orientation="horizontal"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹10"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>


                            <EditText
                                android:id="@+id/et10Count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"

                                android:background="@drawable/edittext_dark_bg"

                                android:gravity="center"
                                android:hint="0"
                                android:inputType="number"
                                android:padding="8dp"

                                android:textColor="#E2E8F0"
                                android:textColorHint="#3A4A60"
                                android:textSize="13sp" />


                            <TextView
                                android:id="@+id/tv10Amount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"

                                android:text="₹0"
                                android:textColor="#4ADE80"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:padding="8dp" />


                        </TableRow>

                    </TableLayout>


                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp"
                        android:background="#1E2D45" />

                    <!-- Coins Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/edittext_row_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"

                            android:text="🪙  Coins Total"
                            android:textColor="#E2E8F0"

                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etCoinsTotal"
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"

                            android:background="@drawable/edittext_dark_bg"
                            android:gravity="center"
                            android:hint="0.00"
                            android:inputType="numberDecimal"
                            android:padding="8dp"
                            android:textColor="#E2E8F0"
                            android:textColorHint="#3A4A60"

                            android:textSize="14sp" />

                    </LinearLayout>


                    <!-- Total Cash Banner -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:background="@drawable/total_banner_green"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"

                            android:text="TOTAL CASH"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />


                        <TextView
                            android:id="@+id/tvTotalCash"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="₹0.00"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"

                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>


    <!-- Save Button -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="56dp"

        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#4ADE80"
        android:text="SAVE CASH COLLECTION"
        android:textColor="#0A0E1A"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        app:cornerRadius="16dp"
        app:elevation="0dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

