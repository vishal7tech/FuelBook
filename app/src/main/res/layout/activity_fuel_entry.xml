                                android:textSize="12sp" />

                        </TableRow>

                        <TableRow android:layout_marginTop="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="N2"
                                android:textColor="@color/text_primary"
