                                android:gravity="center"
                                android:text="0.00"
                                android:textColor="@color/primary_blue"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDieselN3Amount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="0.00"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />

                        </TableRow>

                        <TableRow android:layout_marginTop="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="N4"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold" />

                            <EditText
                                android:id="@+id/etDieselN4Opening"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/edittext_background"
                                android:gravity="center"
                                android:hint="0"
                                android:inputType="number"
                                android:padding="8dp"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />

                            <EditText
                                android:id="@+id/etDieselN4Closing"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/edittext_background"
                                android:gravity="center"
                                android:hint="0"
                                android:inputType="number"
                                android:padding="8dp"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDieselN4Litres"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="0.00"
                                android:textColor="@color/primary_blue"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvDieselN4Amount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="0.00"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />

                        </TableRow>

                    </TableLayout>

                    <!-- Diesel Totals -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvDieselTotalLitres"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Litres: 0.00"
                            android:textColor="@color/primary_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDieselTotalAmount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="Total Amount: 0.00"
                            android:textColor="@android:color/holo_green_dark"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/primary_dark_blue"
        android:text="SAVE FUEL ENTRY"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        app:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
