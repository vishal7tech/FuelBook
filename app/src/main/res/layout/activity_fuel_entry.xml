                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_edit"
                                android:tint="@color/accent_blue" />

                        </LinearLayout>

                    </LinearLayout>

