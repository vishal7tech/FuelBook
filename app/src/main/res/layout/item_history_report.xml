<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <!-- Add any data variables here if needed in the future -->
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"

        android:layout_marginTop="6dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="6dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardBackgroundColor="#111827"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#1E3A5F"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Date Badge -->
            <LinearLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/date_badge_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="14dp">

                <TextView
                    android:id="@+id/tvReportDateDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="03"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="03" />

                <TextView
                    android:id="@+id/tvReportDateMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JAN"
                    android:textColor="#00D4FF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    tools:text="JAN" />

            </LinearLayout>

            <!-- Report Details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvReportDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="03-01-2026"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="03-01-2026" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Daily Report"
                    android:textColor="#8A9BB5"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="P: "
                        android:textColor="#8A9BB5"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvPetrolAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textColor="#00D4FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="₹10,400" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="10dp"
                        android:background="#1E3A5F"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:layout_gravity="center_vertical" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="D: "
                        android:textColor="#8A9BB5"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvDieselAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textColor="#F59E0B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="₹8,900" />

                </LinearLayout>

            </LinearLayout>

            <!-- Grand Total -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL"
                    android:textColor="#8A9BB5"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvGrandTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="₹0"
                    android:textColor="#4ADE80"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="₹19,300" />

                <!-- Chevron -->
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="4dp"
                    android:layout_gravity="end"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="#3A4A60" />


            </LinearLayout>

        </LinearLayout>


    </com.google.android.material.card.MaterialCardView>


</layout>

