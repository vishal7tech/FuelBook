<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"

    android:background="@drawable/dialog_bg"
    android:padding="24dp">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="4dp"
            android:layout_height="24dp"
            android:background="@drawable/accent_bar_blue"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAILY REPORT"
                android:textColor="#00D4FF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <TextView
                android:id="@+id/tvReportDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="03 January 2026"
                android:textColor="#FFFFFF"
                android:textSize="20sp"

                android:textStyle="bold" />

        </LinearLayout>


    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#1E2D45" />

    <!-- Report Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/detail_row_container"
        android:padding="16dp">

        <!-- Petrol Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_blue"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvPetrolDetails"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Petrol: 100.00L → ₹10,400.00"
                android:textColor="#C8D6E8"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Diesel Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_orange"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvDieselDetails"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Diesel: 80.00L → ₹7,120.00"
                android:textColor="#C8D6E8"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Cash Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_green"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvCashDetails"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cash: ₹8,500.00"
                android:textColor="#C8D6E8"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- UPI Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_purple"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvUpiDetails"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="UPI: ₹6,200.00"
                android:textColor="#C8D6E8"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Grand Total Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/total_banner_green"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GRAND TOTAL"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/tvGrandTotalDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash + UPI Collection"
                android:textColor="#CCFFD9"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvGrandTotalAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹17,520.00"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Difference Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/detail_row_container"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Difference"
            android:textColor="#8A9BB5"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvDifferenceDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0.00 ✓"
            android:textColor="#4ADE80"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>


    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGeneratePdf"
            android:layout_width="0dp"

            android:layout_height="46dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#00D4FF"
            android:text="PDF"
            android:textColor="#0A0E1A"
            android:textSize="12sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:elevation="0dp" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="0dp"

            android:layout_height="46dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#1A0A0A"
            android:text="Delete"
            android:textColor="#FF4D6A"
            android:textSize="12sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:strokeColor="#FF4D6A"
            app:strokeWidth="1dp" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOk"
            android:layout_width="0dp"

            android:layout_height="46dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="#111827"
            android:text="OK"
            android:textColor="#8A9BB5"
            android:textSize="12sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:strokeColor="#1E3A5F"
            app:strokeWidth="1dp" />


    </LinearLayout>

</LinearLayout>

