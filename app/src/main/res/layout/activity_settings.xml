<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <!-- Add any data variables here if needed in the future -->
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:background="#0A0E1A"
        tools:context=".SettingsActivity">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/header_dark_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_back"
                android:tint="#8A9BB5"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONFIGURATION"
                    android:textColor="#8A9BB5"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.25" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>


        <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"

            android:layout_marginBottom="8dp"
            android:scrollbars="none"
            app:layout_constraintBottom_toTopOf="@id/btnLogout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerLayout">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">


                <!-- ─── Fuel Prices Card ─── -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFuelPrices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"

                    app:cardBackgroundColor="#111827"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3A5F"
                    app:strokeWidth="1dp">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"

                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="4dp"
                                android:layout_height="22dp"
                                android:background="@drawable/accent_bar_blue"
                                android:layout_marginEnd="10dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Fuel Prices"
                                    android:textColor="#FFFFFF"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Update default prices for calculations"
                                    android:textColor="#8A9BB5"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp"
                            android:background="#1E2D45" />

                        <!-- Petrol Price Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PETROL"
                                    android:textColor="#00D4FF"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.1" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Price per litre"
                                    android:textColor="#8A9BB5"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>


                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"

                                android:background="@drawable/price_chip_bg"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp"

                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹"

                                    android:textColor="#8A9BB5"

                                    android:textSize="14sp" />

                                <EditText
                                    android:id="@+id/etPetrolPrice"
                                    android:layout_width="80dp"
                                    android:layout_height="wrap_content"

                                    android:background="@drawable/edittext_dark_bg"

                                    android:gravity="center"
                                    android:hint="0.00"
                                    android:inputType="numberDecimal"
                                    android:padding="8dp"

                                    android:textColor="#00D4FF"
                                    android:textColorHint="#3A4A60"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />


                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="/L"

                                    android:textColor="#8A9BB5"

                                    android:textSize="14sp" />

                            </LinearLayout>

                        </LinearLayout>


                        <!-- Diesel Price Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DIESEL"
                                    android:textColor="#F59E0B"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.1" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Price per litre"
                                    android:textColor="#8A9BB5"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>


                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"

                                android:background="@drawable/price_chip_bg"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp"

                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹"

                                    android:textColor="#8A9BB5"

                                    android:textSize="14sp" />

                                <EditText
                                    android:id="@+id/etDieselPrice"
                                    android:layout_width="80dp"
                                    android:layout_height="wrap_content"

                                    android:background="@drawable/edittext_dark_bg"

                                    android:gravity="center"
                                    android:hint="0.00"
                                    android:inputType="numberDecimal"
                                    android:padding="8dp"

                                    android:textColor="#F59E0B"
                                    android:textColorHint="#3A4A60"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />


                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="/L"

                                    android:textColor="#8A9BB5"

                                    android:textSize="14sp" />

                            </LinearLayout>

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveFuelPrices"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"

                            android:layout_marginTop="20dp"
                            android:backgroundTint="#00D4FF"
                            android:text="SAVE FUEL PRICES"
                            android:textColor="#0A0E1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            app:cornerRadius="12dp"
                            app:elevation="0dp" />


                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>


                <!-- ─── Nozzles Card ─── -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNozzles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"

                    app:cardBackgroundColor="#111827"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3A5F"
                    app:strokeWidth="1dp">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"

                        android:padding="20dp">


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">


                            <View
                                android:layout_width="4dp"
                                android:layout_height="22dp"
                                android:background="@drawable/accent_bar_orange"
                                android:layout_marginEnd="10dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Manage Nozzles"
                                    android:textColor="#FFFFFF"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Add or remove fuel nozzles"
                                    android:textColor="#8A9BB5"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAddNozzle"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:backgroundTint="#0D1520"
                                android:padding="0dp"
                                app:cornerRadius="10dp"
                                app:elevation="0dp"
                                app:strokeColor="#F59E0B"
                                app:strokeWidth="1dp"
                                app:icon="@drawable/ic_add"
                                app:iconTint="#F59E0B"
                                app:iconSize="20dp"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"
                            android:background="#1E2D45" />


                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewNozzles"
                            android:layout_width="match_parent"

                            android:layout_height="wrap_content"
                            android:maxHeight="250dp"
                            android:scrollbars="vertical"
                            android:nestedScrollingEnabled="true"

                            tools:listitem="@layout/item_nozzle" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>


                <!-- ─── UPI Options Card ─── -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardUpiOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"

                    app:cardBackgroundColor="#111827"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3A5F"
                    app:strokeWidth="1dp">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"

                        android:padding="20dp">


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">


                            <View
                                android:layout_width="4dp"
                                android:layout_height="22dp"
                                android:background="@drawable/accent_bar_purple"
                                android:layout_marginEnd="10dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="UPI Options"
                                    android:textColor="#FFFFFF"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Manage UPI payment methods"
                                    android:textColor="#8A9BB5"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAddUpiOption"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:backgroundTint="#0D1520"
                                android:padding="0dp"
                                app:cornerRadius="10dp"
                                app:elevation="0dp"
                                app:strokeColor="#A78BFA"
                                app:strokeWidth="1dp"
                                app:icon="@drawable/ic_add"
                                app:iconTint="#A78BFA"
                                app:iconSize="20dp"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"
                            android:background="#1E2D45" />


                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewUpiOptions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"

                            android:maxHeight="250dp"
                            android:scrollbars="vertical"
                            android:nestedScrollingEnabled="true"

                            tools:listitem="@layout/item_upi_option" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>


        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#1A0A0A"
            android:text="LOGOUT"
            android:textColor="#FF4D6A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            app:strokeColor="#FF4D6A"
            app:strokeWidth="1dp"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>

