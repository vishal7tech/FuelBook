<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="#0A0E1A"
    tools:context=".MainActivity">

    <!-- Decorative gradient overlay at top -->
    <View
        android:id="@+id/gradientOverlay"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="@drawable/gradient_header_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Status bar spacer -->
    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="315dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.25"
                android:text="FUEL BOOK"
                android:textColor="#00D4FF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPumpName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="HP Pump"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Welcome, Vishal Chaudhari"
                android:textColor="#8A9BB5"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Profile Icon -->

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Profile"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/circle_accent_border" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_profile"
            android:layout_marginStart="-32dp"
            android:layout_marginTop="12dp"
            android:clickable="false"
            android:focusable="false" />

    </LinearLayout>

    <!-- Today's Date Chip -->
    <TextView
        android:id="@+id/tvTodayDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/chip_date_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="● Today, 03 Jan 2026"
        android:textColor="#00D4FF"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Main Content ScrollView -->
    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvTodayDate"
        app:layout_constraintBottom_toTopOf="@id/btnLogout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"

            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Grid of Action Cards -->

            <GridLayout
                android:id="@+id/gridButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"

                android:rowCount="3"
                android:useDefaultMargins="false">

                <!-- Fuel Entry Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnFuelEntry"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#111827"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3A5F"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_gas_station"
                            android:padding="12dp"
                            android:background="@drawable/icon_bg_blue" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fuel Entry"
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Accent top border -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="0dp"
                        android:background="@drawable/accent_line_blue" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Cash Collection Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnCashCollection"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#111827"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3A5F"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_money"
                            android:padding="12dp"
                            android:background="@drawable/icon_bg_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cash Collection"
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/accent_line_green" />

                </com.google.android.material.card.MaterialCardView>

                <!-- UPI Collection Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnUpiCollection"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#111827"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3A5F"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_qr_code"
                            android:padding="12dp"
                            android:background="@drawable/icon_bg_purple" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UPI Collection"
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/accent_line_purple" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Daily Summary Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnDailySummary"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#111827"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3A5F"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_report"
                            android:padding="12dp"
                            android:background="@drawable/icon_bg_orange" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Summary"
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/accent_line_orange" />

                </com.google.android.material.card.MaterialCardView>

                <!-- History Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnHistory"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#111827"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3A5F"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_history"
                            android:padding="12dp"
                            android:background="@drawable/icon_bg_cyan" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="History"
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/accent_line_cyan" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Settings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnSettings"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#111827"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E3A5F"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_settings"
                            android:padding="12dp"
                            android:background="@drawable/icon_bg_gray" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Settings"
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:layout_gravity="top|center_horizontal"
                        android:background="@drawable/accent_line_gray" />

                </com.google.android.material.card.MaterialCardView>


            </GridLayout>

        </LinearLayout>


    </ScrollView>

    <!-- Logout Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#1A0A0A"
        android:text="LOGOUT"
        android:textColor="#FF4D6A"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:cornerRadius="16dp"
        app:elevation="0dp"
        app:strokeColor="#FF4D6A"
        app:strokeWidth="1dp"
        app:icon="@drawable/ic_logout"
        app:iconTint="#FF4D6A"
        app:iconGravity="textStart"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

