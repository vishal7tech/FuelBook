<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_blue"
            android:title="FuelBook"
            android:titleTextColor="@color/white"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6" />

    </com.google.android.material.appbar.AppBarLayout>

    <TextView
        android:id="@+id/tvPumpName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="HP Pump"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Welcome, Vishal Chaudhari"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPumpName" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMain"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <GridLayout
                android:id="@+id/gridButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3">

                <!-- Fuel Entry Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFuelEntry"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/card_background"
                    android:text="Fuel Entry"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"
                    app:icon="@drawable/ic_gas_station"
                    app:iconGravity="top"
                    app:iconSize="32dp"
                    app:iconTint="@color/primary_blue"
                    app:strokeColor="@color/accent_blue"
                    app:strokeWidth="1dp" />

                <!-- Cash Collection Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCashCollection"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/card_background"
                    android:text="Cash Collection"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"
                    app:icon="@drawable/ic_money"
                    app:iconGravity="top"
                    app:iconSize="32dp"
                    app:iconTint="@color/primary_blue"
                    app:strokeColor="@color/accent_blue"
                    app:strokeWidth="1dp" />

                <!-- UPI Collection Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpiCollection"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/card_background"
                    android:text="UPI Collection"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"
                    app:icon="@drawable/ic_qr_code"
                    app:iconGravity="top"
                    app:iconSize="32dp"
                    app:iconTint="@color/primary_blue"
                    app:strokeColor="@color/accent_blue"
                    app:strokeWidth="1dp" />

                <!-- Daily Summary Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDailySummary"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/card_background"
                    android:text="Daily Summary"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"
                    app:icon="@drawable/ic_report"
                    app:iconGravity="top"
                    app:iconSize="32dp"
                    app:iconTint="@color/primary_blue"
                    app:strokeColor="@color/accent_blue"
                    app:strokeWidth="1dp" />

                <!-- History Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistory"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/card_background"
                    android:text="History"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"
                    app:icon="@drawable/ic_history"
                    app:iconGravity="top"
                    app:iconSize="32dp"
                    app:iconTint="@color/primary_blue"
                    app:strokeColor="@color/accent_blue"
                    app:strokeWidth="1dp" />

                <!-- Settings Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettings"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/card_background"
                    android:text="Settings"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:elevation="4dp"
                    app:icon="@drawable/ic_settings"
                    app:iconGravity="top"
                    app:iconSize="32dp"
                    app:iconTint="@color/primary_blue"
                    app:strokeColor="@color/accent_blue"
                    app:strokeWidth="1dp" />

            </GridLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/logout_red"
        android:text="LOGOUT"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        app:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
