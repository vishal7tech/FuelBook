<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <!-- Add any data variables here if needed in the future -->
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"

        app:cardBackgroundColor="#0D1520"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="#1E3A5F"
        app:strokeWidth="1dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"

            android:paddingStart="14dp"
            android:paddingEnd="8dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- Nozzle Icon Badge -->
            <View
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/icon_bg_orange_small"
                android:layout_marginEnd="12dp" />

            <!-- Nozzle Name -->

            <TextView
                android:id="@+id/tvNozzleName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="N1"

                android:textColor="#FFFFFF"
                android:textSize="15sp"

                android:textStyle="bold"
                tools:text="N1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:layout_marginEnd="10dp"
                android:text="Nozzle"
                android:textColor="#3A4A60"
                android:textSize="11sp"
                android:background="@drawable/chip_small_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoveNozzle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:backgroundTint="#1A0A0A"
                android:padding="0dp"
                app:cornerRadius="8dp"
                app:elevation="0dp"
                app:strokeColor="#FF4D6A"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_delete"
                app:iconTint="#FF4D6A"
                app:iconSize="16dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />


        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</layout>

